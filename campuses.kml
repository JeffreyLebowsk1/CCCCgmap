    <!-- ============================================================
         LEE COUNTY CAMPUS
         ============================================================ -->
    <Folder>
      <name>Lee County Campus – Sanford, NC</name>
      <description><![CDATA[
        1105 Kelly Drive, Sanford, NC 27330<br/>
        Phone: (919) 775-5401<br/>
        <a href="https://www.cccc.edu/campuses/lee/">Campus Website</a>
      ]]></description>
      <open>1</open>

      <Placemark>
        <name>Cameron Hall</name>
        <description><![CDATA[
          <b>Building Code:</b> CAM<br/>
          <b>Campus:</b> Lee County Campus<br/>
          <b>Type:</b> Academic<br/>
          <b>Description:</b> Administrative offices, admissions, financial aid,
          and general education classrooms.<br/>
          <b>Departments:</b> Administration, Admissions, Financial Aid, Business Office<br/>
          <b>Hours:</b> Mon–Fri 8:00 AM – 5:00 PM<br/>
          <b>Wheelchair Accessible:</b> Yes<br/>
          <a href="https://www.google.com/maps/dir/?api=1&amp;destination=35.4801,-79.1893&amp;travelmode=driving">Get Directions</a>
        ]]></description>
        <styleUrl>#style-academic</styleUrl>
        <ExtendedData>
          <SchemaData schemaUrl="#CCCCBuilding">
            <SimpleData name="buildingCode">CAM</SimpleData>
            <SimpleData name="buildingType">academic</SimpleData>
            <SimpleData name="campus">Lee County Campus</SimpleData>
            <SimpleData name="address">1105 Kelly Drive, Sanford, NC 27330</SimpleData>
            <SimpleData name="phone">(919) 775-5401</SimpleData>
            <SimpleData name="hours">Mon–Fri 8:00 AM – 5:00 PM</SimpleData>
            <SimpleData name="departments">Administration; Admissions; Financial Aid; Business Office</SimpleData>
            <SimpleData name="accessible">true</SimpleData>
          </SchemaData>
        </ExtendedData>
        <Point>
          <altitudeMode>relativeToGround</altitudeMode>
          <coordinates>-79.1893,35.4801,0</coordinates>
        </Point>
      </Placemark>

      <Placemark>
        <name>Dennis A. Wicker Civic &amp; Conference Center</name>
        <description><![CDATA[
          <b>Building Code:</b> DWACC<br/>
          <b>Campus:</b> Lee County Campus<br/>
          <b>Type:</b> Event Venue<br/>
          <b>Description:</b> Civic and conference center hosting college events,
          community programs, and large gatherings.<br/>
          <b>Departments:</b> Event Services, Community Programs<br/>
          <b>Hours:</b> Varies by event<br/>
          <b>Wheelchair Accessible:</b> Yes<br/>
          <a href="https://www.google.com/maps/dir/?api=1&amp;destination=35.4793,-79.1888&amp;travelmode=driving">Get Directions</a>
        ]]></description>
