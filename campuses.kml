<?xml version="1.0" encoding="UTF-8"?>
<!--
  CCCC Campus Map – KML 2.2
  Central Carolina Community College

  USAGE – Google My Maps submission:
  1. Go to https://www.google.com/maps/d/
  2. Click "Create a new map" → "Import"
  3. Upload this file (campuses.kml).
  4. Review, then use "Share" → "Publish to web".
  5. For official Google Maps listing, submit via
     Google Maps Connect: https://maps.google.com/maps/user-msft-connect

  USAGE – Google Maps Platform (KML Layer):
  Host this file at a public HTTPS URL, then in your JavaScript:
    new google.maps.KmlLayer({
      url: 'https://yourdomain.com/campuses.kml',
      map: map,
      preserveViewport: false,
    });
-->
<kml xmlns="http://www.opengis.net/kml/2.2"
     xmlns:gx="http://www.google.com/kml/ext/2.2"
     xmlns:atom="http://www.w3.org/2005/Atom">

  <Document>
    <name>Central Carolina Community College – Campus Map</name>
    <description><![CDATA[
      Interactive campus map for Central Carolina Community College (CCCC).
      Includes building locations, departments, hours, and accessibility
      information for all four CCCC campuses in North Carolina.
      Website: https://www.cccc.edu
    ]]></description>

    <atom:author>
      <atom:name>Central Carolina Community College</atom:name>
    </atom:author>
    <atom:link href="https://www.cccc.edu" />

    <!-- ============================================================
         SHARED SCHEMA
         ExtendedData schema lets Google My Maps and third-party KML
         consumers (e.g., ArcGIS, QGIS) read typed attributes.
         ============================================================ -->
    <Schema name="CCCCBuilding" id="CCCCBuilding">
      <SimpleField type="string"  name="buildingCode">
        <displayName>Building Code</displayName>
      </SimpleField>
      <SimpleField type="string"  name="buildingType">
        <displayName>Building Type</displayName>
      </SimpleField>
      <SimpleField type="string"  name="campus">
        <displayName>Campus</displayName>
      </SimpleField>
      <SimpleField type="string"  name="address">
        <displayName>Address</displayName>
      </SimpleField>
      <SimpleField type="string"  name="phone">
        <displayName>Phone</displayName>
      </SimpleField>
      <SimpleField type="string"  name="hours">
        <displayName>Hours</displayName>
      </SimpleField>
      <SimpleField type="string"  name="departments">
        <displayName>Departments / Services</displayName>
      </SimpleField>
      <SimpleField type="bool"    name="accessible">
        <displayName>Wheelchair Accessible</displayName>
      </SimpleField>
    </Schema>

    <Schema name="CCCCParking" id="CCCCParking">
      <SimpleField type="string"  name="campus">
        <displayName>Campus</displayName>
      </SimpleField>
      <SimpleField type="string"  name="lotName">
        <displayName>Lot Name</displayName>
      </SimpleField>
    </Schema>

    <!-- ============================================================
         SHARED STYLES
         One StyleMap per building type; each maps normal/highlight
         states – required by the KML 2.2 spec for proper rendering
         in Google Earth and Google My Maps.
         ============================================================ -->

    <!-- Academic (blue) -->
    <Style id="academic-normal">
      <IconStyle>
        <color>ff870030</color><!-- AABBGGRR – blue #003087 -->
        <scale>1.1</scale>
        <Icon><href>https://maps.google.com/mapfiles/kml/paddle/blu-blank.png</href></Icon>
        <hotSpot x="0.5" y="0" xunits="fraction" yunits="fraction"/>
      </IconStyle>
      <LabelStyle><scale>0</scale></LabelStyle>
      <BalloonStyle>
        <text><![CDATA[<b>$[name]</b><br/>$[description]]]></text>
      </BalloonStyle>
    </Style>
    <Style id="academic-highlight">
      <IconStyle>
        <color>ff870030</color>
        <scale>1.3</scale>
        <Icon><href>https://maps.google.com/mapfiles/kml/paddle/blu-blank.png</href></Icon>
        <hotSpot x="0.5" y="0" xunits="fraction" yunits="fraction"/>
      </IconStyle>
      <LabelStyle><scale>0.9</scale></LabelStyle>
    </Style>
    <StyleMap id="style-academic">
      <Pair><key>normal</key>   <styleUrl>#academic-normal</styleUrl></Pair>
      <Pair><key>highlight</key><styleUrl>#academic-highlight</styleUrl></Pair>
    </StyleMap>

    <!-- Services (teal) -->
    <Style id="services-normal">
      <IconStyle>
        <color>ffcc7700</color><!-- teal #0077CC -->
        <scale>1.1</scale>
        <Icon><href>https://maps.google.com/mapfiles/kml/paddle/ltblu-blank.png</href></Icon>
        <hotSpot x="0.5" y="0" xunits="fraction" yunits="fraction"/>
      </IconStyle>
      <LabelStyle><scale>0</scale></LabelStyle>
    </Style>
    <Style id="services-highlight">
      <IconStyle>
        <color>ffcc7700</color>
        <scale>1.3</scale>
        <Icon><href>https://maps.google.com/mapfiles/kml/paddle/ltblu-blank.png</href></Icon>
        <hotSpot x="0.5" y="0" xunits="fraction" yunits="fraction"/>
      </IconStyle>
      <LabelStyle><scale>0.9</scale></LabelStyle>
    </Style>
    <StyleMap id="style-services">
      <Pair><key>normal</key>   <styleUrl>#services-normal</styleUrl></Pair>
      <Pair><key>highlight</key><styleUrl>#services-highlight</styleUrl></Pair>
    </StyleMap>

