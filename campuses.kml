    <!-- ============================================================
         LEE COUNTY CAMPUS
         ============================================================ -->
    <Folder>
      <name>Lee County Campus – Sanford, NC</name>
      <description><![CDATA[
        1105 Kelly Drive, Sanford, NC 27330<br/>
        Phone: (919) 775-5401<br/>
        <a href="https://www.cccc.edu/campuses/lee/">Campus Website</a>
      ]]></description>
      <open>1</open>

      <Placemark>
        <name>Douglas H. Wilkinson Sr. Hall</name>
        <description><![CDATA[
          <b>Building Code:</b> 1<br/>
          <b>Campus:</b> Lee County Campus<br/>
          <b>Type:</b> Academic<br/>
          <b>Description:</b> Academic programs including Broadcasting, Business, Engineering, Information Technologies, and Machining. Houses classrooms and faculty offices.<br/>
          <b>Departments:</b> Broadcasting; Business Administration; Engineering; Information Technologies; Machining<br/>
          <b>Hours:</b> Mon–Fri 7:30 AM – 9:00 PM<br/>
          <b>Wheelchair Accessible:</b> Yes<br/>
          <a href="https://www.google.com/maps/dir/?api=1&amp;destination=35.4815,-79.1907&amp;travelmode=driving">Get Directions</a>
        ]]></description>
        <styleUrl>#style-academic</styleUrl>
        <ExtendedData>
          <SchemaData schemaUrl="#CCCCBuilding">
            <SimpleData name="buildingCode">1</SimpleData>
            <SimpleData name="buildingType">academic</SimpleData>
            <SimpleData name="campus">Lee County Campus</SimpleData>
            <SimpleData name="address">1105 Kelly Drive, Sanford, NC 27330</SimpleData>
            <SimpleData name="phone">(919) 775-5401</SimpleData>
            <SimpleData name="hours">Mon–Fri 7:30 AM – 9:00 PM</SimpleData>
            <SimpleData name="departments">Broadcasting; Business Administration; Engineering; Information Technologies; Machining</SimpleData>
            <SimpleData name="accessible">true</SimpleData>
          </SchemaData>
        </ExtendedData>
        <Point>
          <altitudeMode>relativeToGround</altitudeMode>
          <coordinates>-79.1907,35.4815,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Guided Studies</name>
        <description><![CDATA[
          <b>Building Code:</b> 2<br/>
          <b>Campus:</b> Lee County Campus<br/>
          <b>Type:</b> Student Services<br/>
          <b>Description:</b> Guided Studies programs providing developmental education and academic support for students.<br/>
          <b>Departments:</b> Guided Studies; Developmental Education<br/>
          <b>Hours:</b> Mon–Fri 7:30 AM – 9:00 PM<br/>
          <b>Wheelchair Accessible:</b> Yes<br/>
          <a href="https://www.google.com/maps/dir/?api=1&amp;destination=35.4805,-79.1911&amp;travelmode=driving">Get Directions</a>
        ]]></description>
